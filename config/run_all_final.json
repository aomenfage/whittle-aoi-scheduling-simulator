{
  "generate_readme": true,
  "generate_summary_template": true,
  "run_tests": true,
  "standard_suite": {
    "config_path": "config/runner_final.json"
  },
  "extended_suite": {
    "output_root": "results/final_extended_suite",
    "enabled": true
  },
  "single_arm_mdp": {
    "enabled": true,
    "weight": 2.0,
    "success_prob": 0.8,
    "lambda_value": 8.0,
    "a_max": 40,
    "lambda_mode": "passive_subsidy",
    "output_dir": "results/final_single_arm_mdp"
  },
  "baseline_compare": {
    "enabled": true,
    "strategies": ["round_robin", "periodic", "greedy", "random"],
    "horizon": 3000,
    "seed": 2026,
    "high_weight_threshold": 2.0,
    "output_dir": "results/final_exp_compare"
  },
  "whittle_demo": {
    "enabled": true,
    "max_test_aoi": 12,
    "output_csv": "results/final_whittle_demo/whittle_vs_greedy_demo.csv"
  }
}
