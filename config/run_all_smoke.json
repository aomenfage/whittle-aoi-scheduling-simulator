{
  "generate_readme": true,
  "generate_summary_template": true,
  "run_tests": true,
  "standard_suite": {
    "config_path": "config/runner_smoke.json"
  },
  "extended_suite": {
    "output_root": "results/run_all_smoke_extended",
    "enabled": false
  },
  "single_arm_mdp": {
    "enabled": true,
    "weight": 2.0,
    "success_prob": 0.8,
    "lambda_value": 4.0,
    "a_max": 12,
    "lambda_mode": "passive_subsidy",
    "output_dir": "results/run_all_smoke_single_arm"
  },
  "baseline_compare": {
    "enabled": true,
    "strategies": ["round_robin", "periodic", "greedy", "random"],
    "horizon": 80,
    "seed": 2026,
    "high_weight_threshold": 2.0,
    "output_dir": "results/run_all_smoke_compare"
  },
  "whittle_demo": {
    "enabled": true,
    "max_test_aoi": 6,
    "output_csv": "results/run_all_smoke_demo/whittle_vs_greedy_demo.csv"
  }
}
